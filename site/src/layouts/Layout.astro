---
import Header from "../components/Header.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>PlayStatus &mdash; Now Playing for Teams</title>
    <meta name="title" content="PlayStatus &mdash; Now Playing for Teams" />
    <meta name="description" content="A desktop app that publishes your currently playing Spotify track to your Microsoft Teams status" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="PlayStatus &mdash; Now Playing for Teams" />
    <meta property="og:description" content="A desktop app that publishes your currently playing Spotify track to your Microsoft Teams status" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="PlayStatus &mdash; Now Playing for Teams" />
    <meta property="twitter:description" content="A desktop app that publishes your currently playing Spotify track to your Microsoft Teams status" />

    <meta name="robots" content="index, follow" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <p>&copy; {new Date().getFullYear()} <a href="https://craigv.me/" target="_blank" rel="noopener">Craig Vincent</a>. Open source under the <a href="https://github.com/craigvincent/playstatus/blob/master/LICENSE" target="_blank" rel="noopener">MIT license</a>.</p>
          <nav class="footer-links" aria-label="Footer">
            <a href="https://github.com/craigvincent/playstatus" target="_blank" rel="noopener">GitHub</a>
            <a href="https://github.com/craigvincent/playstatus/releases" target="_blank" rel="noopener">Releases</a>
          </nav>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border-subtle);
    padding: 1.5rem 0;
    margin-top: 6rem;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .footer-inner p {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-inner p a {
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-medium);
    transition: all 0.2s;
  }

  .footer-inner p a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--accent);
  }
</style>
