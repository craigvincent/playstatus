---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="page-hero">
    <div class="container">
      <h1>Download</h1>
      <p>Choose your platform. Single-file executables, no installer required.</p>
    </div>
  </section>

  <section class="downloads">
    <div class="container">
      <div class="download-grid">
        <div class="download-card">
          <div class="card-top">
            <div class="os-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.45H0m10.949-9.6L24 0v11.4H10.949M0 12.6h9.75v9.45L0 20.55M10.949 12.6H24V24l-12.9-1.8"/></svg>
            </div>
            <h2>Windows</h2>
            <p class="arch">64-bit &middot; ~80 MB</p>
          </div>
          <a href="https://github.com/craigvincent/playstatus/releases/latest/download/PlayStatus-win-x64.zip" class="btn-download">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download for Windows
          </a>
        </div>

        <div class="download-card">
          <div class="card-top">
            <div class="os-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.82-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.88 1.94-1.46 3.03-1.5.15 1.61-.44 3.22-1.32 4.36-.86 1.1-2.27 1.96-3.66 1.84-.17-1.58.5-3.18 1.95-4.7"/></svg>
            </div>
            <h2>macOS Intel</h2>
            <p class="arch">x64 &middot; ~90 MB</p>
          </div>
          <a href="https://github.com/craigvincent/playstatus/releases/latest/download/PlayStatus-osx-x64.zip" class="btn-download">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download for macOS Intel
          </a>
        </div>

        <div class="download-card">
          <div class="card-top">
            <div class="os-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.82-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.88 1.94-1.46 3.03-1.5.15 1.61-.44 3.22-1.32 4.36-.86 1.1-2.27 1.96-3.66 1.84-.17-1.58.5-3.18 1.95-4.7"/></svg>
            </div>
            <h2>macOS Apple Silicon</h2>
            <p class="arch">ARM64 &middot; ~85 MB</p>
          </div>
          <a href="https://github.com/craigvincent/playstatus/releases/latest/download/PlayStatus-osx-arm64.zip" class="btn-download">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download for macOS Silicon
          </a>
        </div>
      </div>

      <div class="build-source">
        <div class="source-card">
          <div class="source-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <div>
            <h3>Build from source</h3>
            <p>Requires the <a href="https://dotnet.microsoft.com/download/dotnet/10.0" target="_blank" rel="noopener">.NET 10 SDK</a>. Clone the repo and run <code>dotnet run --project src/desktop_app</code>.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 5rem 0 2.5rem;
    position: relative;
    z-index: 1;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .page-hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
  }

  .downloads {
    padding: 2rem 0 5rem;
    position: relative;
    z-index: 1;
  }

  .download-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .download-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: all 0.3s;
  }

  .download-card:hover {
    border-color: var(--border-medium);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .card-top {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .os-icon {
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .download-card h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .arch {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--accent);
    color: var(--bg-deep);
    border-radius: 12px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: -0.01em;
    transition: all 0.25s;
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .btn-download:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 35px var(--accent-glow);
  }

  .build-source {
    margin-top: 2rem;
  }

  .source-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    transition: border-color 0.3s;
  }

  .source-card:hover {
    border-color: var(--border-medium);
  }

  .source-icon {
    color: var(--text-muted);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .source-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin-bottom: 0.35rem;
  }

  .source-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .source-card a {
    color: var(--accent);
    border-bottom: 1px solid rgba(29, 185, 84, 0.3);
    transition: border-color 0.2s;
  }

  .source-card a:hover {
    border-color: var(--accent);
  }

  @media (max-width: 640px) {
    .download-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
